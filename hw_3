//[과제3] 3차원 배열을 이용해 문자배열 입출력하기
#include <stdio.h>

int main() {
    char str[2][3][20];

    for (int i = 0; i < 2; i++) {
        for (int j=0; j <3; j++) {
            if (j == 0) printf("학생 %d의 이름 : ", i + 1);
            else if (j == 1) printf("학생 %d의 학과 : ", i + 1);
            else printf("학생 %d의 학번 : ", i + 1);


			//띄어쓰기 포함 입력 받기 위해서 fgets 사용
            fgets(str[i][j], 20, stdin);
            str[i][j][strcspn(str[i][j], "\n")] = '\0';
        }
        printf("\n");
    }

    for (int i = 0; i < 2; i++) {
        printf("학생 %d\n", i + 1);

        for (int j = 0; j < 3; j++) {
            printf("    %s\n", str[i][j]);
        }
        printf("\n");
    }

    return 0;
}

